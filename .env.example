# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, used by webhooks

# ===== ConvertKit / Kit (newsletter) =====
KIT_API_KEY=your-kit-api-key
KIT_FORM_ID=your-kit-form-id

# ===== Stripe (broker subscriptions) =====
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STANDARD=price_xxx   # $299/mo recurring price ID
STRIPE_PRICE_FEATURED=price_xxx   # $499/mo recurring price ID

# ===== Apify (listing data) =====
APIFY_TOKEN=apify_api_xxx
APIFY_WEBHOOK_SECRET=choose-a-random-string   # appended as ?secret=... to your webhook URL

# ===== Analytics & Search Console =====
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX                 # Google Analytics 4 measurement ID (loads only after cookie consent)
NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-code     # Google Search Console "HTML tag" verification code
